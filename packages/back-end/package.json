{
  "name": "@sga/back-end",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest --config vitest.integration.config.ts",
    "test:functional": "vitest --config vitest.functional.config.ts",
    "build:sidecar": "node scripts/build-pkg.js && node scripts/copy-prisma.js && node scripts/concat-migrations.js"
  },
  "pkg": {
    "scripts": "dist/**/*.js"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^6.12.0",
    "@sga/data-access": "*",
    "@trpc/server": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.24.0",
    "jsonwebtoken": "^9.0.3",
    "mnemonist": "^0.39.6",
    "node-cron": "^4.6.0",
    "papaparse": "^5.5.4",
    "vary": "^1.1.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.4.5",
    "esbuild": "^0.28.1",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.5",
    "typescript": "^5.2.2",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "^4.0.0"
  }
}
