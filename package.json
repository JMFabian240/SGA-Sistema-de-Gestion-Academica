{
  "name": "sga-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:front-end": "npm run dev --workspace=@sga/front-end",
    "dev:back-end": "npm run dev --workspace=@sga/back-end",
    "dev:tauri": "npm run tauri dev --workspace=@sga/app-tauri",
    "dev": "npm run dev:back-end & npm run dev:front-end",
    "build:back": "npm run build --workspace=@sga/back-end",
    "db:migrate": "npm run db:migrate --workspace=@sga/data-access",
    "db:studio": "npm run db:studio --workspace=@sga/data-access",
    "test:e2e": "npm run test --workspace=@sga/e2e",
    "test:e2e:ui": "npm run test:ui --workspace=@sga/e2e"
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
