@startuml rf_60_registrar_un_pago
left to right direction
skinparam packageStyle rectangle

actor "Administrador / Gestor" as Actor
boundary "Caja UI\n(Vite/React)" as PantallaCaja
control "pagosRouter / tRPC" as Router
control "PagosService / Repository" as ServiceRepo
entity "Tutor" as TutorEntity
entity "CalendarioPago\n(Adeudos)" as AdeudoEntity
entity "Pago" as PagoEntity
entity "AplicacionPago" as AplicacionEntity
entity "MovimientoSaldo" as SaldoEntity
entity "LogAuditoria" as AuditoriaEntity

Actor --> PantallaCaja : Busca tutor/alumno y selecciona deudas
PantallaCaja --> Router : registrarPago(input)
Router --> ServiceRepo : registrarPagoTransaccion()

ServiceRepo --> AdeudoEntity : Consulta saldos pendientes
ServiceRepo --> PagoEntity : Crea registro de Pago
ServiceRepo --> AplicacionEntity : Crea aplicaciones del pago
ServiceRepo --> AdeudoEntity : Actualiza saldoPendiente y estadoCobro (PAGADO/PENDIENTE)

alt Si hay excedente de pago (montoTotal > totalAplicado)
  ServiceRepo --> TutorEntity : Incrementa saldoAFavor
  ServiceRepo --> SaldoEntity : Crea MovimientoSaldo (INGRESO)
end

ServiceRepo --> AuditoriaEntity : Registra log de auditoría
ServiceRepo --> Router : Retorna confirmación de transacción
Router --> PantallaCaja : Despliega ticket digital de pago
PantallaCaja --> Actor : Muestra ticket y actualiza Dashboard
@enduml
